# llm-prompting - Environment Variables
# Copy this file to .env and fill in the values, then `uv run query_nemotron.py`

# NVIDIA Nemotron LLM endpoint (OpenAI-compatible /chat/completions). REQUIRED.
NEMOTRON_LLM_URL=

# Model name to request (optional; default below).
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super

# Enable the model's <think> reasoning trace ("true"/"false"). Optional, default false.
NEMOTRON_ENABLE_THINKING=false

# Where query_nemotron.py appends results. Optional; defaults to a timestamped file.
# OUT_PATH=tactical_results.txt
