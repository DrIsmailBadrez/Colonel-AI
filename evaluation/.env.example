# llm-prompting - Environment Variables
# Copy this file to .env and fill in the values, then `uv run query_nemotron.py`

# NVIDIA Nemotron LLM endpoint (OpenAI-compatible /chat/completions). REQUIRED.
NEMOTRON_LLM_URL=

# Model name to request (optional; default below).
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super

# Enable the model's <think> reasoning trace ("true"/"false"). Optional, default false.
# PERFORMANCE: this is the biggest latency lever. OFF = ~1-3s answers (~90-100
# tok/s); ON = the model emits a long reasoning trace first and often takes
# >120s. Keep OFF for the voice agent unless you need the reasoning trace.
NEMOTRON_ENABLE_THINKING=false

# Sampling knobs (optional). The five-line output is ~80-130 tokens, so a small
# max_tokens caps worst-case latency; low temperature keeps answers deterministic.
NEMOTRON_MAX_TOKENS=256
NEMOTRON_TEMPERATURE=0.2
NEMOTRON_TOP_P=0.9

# Where query_nemotron.py / query_claude.py append results. Optional; defaults to
# a timestamped file.
# OUT_PATH=tactical_results.txt

# --- Anthropic Claude (query_claude.py) ---
# API key from https://console.anthropic.com/settings/keys. REQUIRED for query_claude.py.
ANTHROPIC_API_KEY=
# Model to request (optional; default below). Use claude-opus-4-8 for best quality.
CLAUDE_MODEL=claude-opus-4-8
# Enable Claude's native adaptive thinking ("true"/"false"). Optional, default false.
# The tactical prompt asks the model to emit its own inline <think> block + the
# five output lines as text (so parse_results.py can read them). Leave this OFF to
# keep that contract; turning it ON routes reasoning into separate (by default
# omitted) thinking blocks instead.
CLAUDE_ENABLE_THINKING=false
# Output-token ceiling (optional). The five-line answer is short; bump it if you
# enable thinking. Streaming is used, so a larger value is safe.
CLAUDE_MAX_TOKENS=2048
